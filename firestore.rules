rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin()
                  || (request.auth != null && resource.data.email == request.auth.token.email && resource.data.isPending == true);
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow delete: if isAdmin()
                    || (request.auth != null && resource.data.email == request.auth.token.email && resource.data.isPending == true);

      match /sessions/{sessionId} {
        allow read: if isOwner(uid) || isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email);
        allow create, update, delete: if isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email && get(/databases/$(database)/documents/users/$(uid)).data.isPending == true);

        match /comments/{commentId} {
          allow read: if isOwner(uid) || isAdmin();
          allow create: if isOwner(uid) || isAdmin();
          allow update, delete: if isAdmin();
        }
      }

      match /jobAnalyses/{analysisId} {
        allow read: if isOwner(uid) || isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email);
        allow create: if isOwner(uid) || isAdmin();
        allow update, delete: if isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email && get(/databases/$(database)/documents/users/$(uid)).data.isPending == true);

        match /comments/{commentId} {
          allow read: if isOwner(uid) || isAdmin();
          allow create: if isOwner(uid) || isAdmin();
          allow update, delete: if isAdmin();
        }
      }

      match /resumeReviews/{reviewId} {
        allow read: if isOwner(uid) || isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email);
        allow create, update, delete: if isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email && get(/databases/$(database)/documents/users/$(uid)).data.isPending == true);

        match /comments/{commentId} {
          allow read: if isOwner(uid) || isAdmin();
          allow create: if isOwner(uid) || isAdmin();
          allow update, delete: if isAdmin();
        }
      }

      match /progress/{docId} {
        allow read: if isOwner(uid) || isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email);
        allow create, update: if isAdmin()
                    || (request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email && get(/databases/$(database)/documents/users/$(uid)).data.isPending == true);
        allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(uid)).data.email == request.auth.token.email && get(/databases/$(database)/documents/users/$(uid)).data.isPending == true;
      }
    }

    match /pendingInvites/{inviteId} {
      allow read, delete: if request.auth != null;
      allow create, update: if isAdmin();
    }
  }
}
