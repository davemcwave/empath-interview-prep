# Copy this file to .env and fill in real values. Do not commit .env.

# Gmail account used to send the digest.
# If using a personal Gmail, enable 2FA and create an App Password:
#   https://myaccount.google.com/apppasswords
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: override the From address (defaults to SMTP_USER).
SENDER=your.gmail@gmail.com

# Where the digest gets sent.
RECIPIENT=david@empathinterviews.com

# Optional SMTP overrides. Defaults are Gmail.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587

# Optional: override the User-Agent sent to Reddit.
# USER_AGENT=Empath:reddit-digest:0.1 (by /u/your-reddit-username)
