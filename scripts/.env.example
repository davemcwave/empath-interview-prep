# Copy this file to .env and fill in real values. Do not commit .env.

# --- Reddit OAuth ---
# Required when running from cloud IPs (e.g. GitHub Actions). Optional for local
# testing from a residential IP, where the unauthenticated endpoint still works.
#
# Create a "script" type app at: https://www.reddit.com/prefs/apps
# After creating, you'll see:
#   - the client ID under the app name (a short string like "abc123XYZ")
#   - the client secret labeled "secret"
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password

# --- Email (Gmail SMTP) ---
# If using a personal Gmail, enable 2FA and create an App Password:
#   https://myaccount.google.com/apppasswords
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Optional: override the From address (defaults to SMTP_USER).
SENDER=your.gmail@gmail.com

# Where the digest gets sent.
RECIPIENT=david@empathinterviews.com

# --- Optional overrides ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# USER_AGENT=Empath:reddit-digest:0.1 (by /u/your-reddit-username)
